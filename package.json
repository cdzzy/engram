{
  "name": "engram",
  "version": "0.1.0",
  "description": "Standardized long-term memory for AI agents — forgetting curve compression, shared memory spaces, memory versioning, and MCP stdio server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "engram-mcp": "./dist/mcp-stdio.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent",
    "memory",
    "long-term-memory",
    "forgetting-curve",
    "ebbinghaus",
    "multi-agent",
    "shared-memory",
    "memory-versioning",
    "ai-agent",
    "llm",
    "mcp",
    "model-context-protocol",
    "stdio",
    "memory-graph"
  ],
  "author": "cdzzy",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
